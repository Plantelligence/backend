# ── Servidor ────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-refresh-secret
PASSWORD_RESET_SECRET=change-password-reset-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TTL_SECONDS=900
PASSWORD_EXPIRY_DAYS=90

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5

# ── PostgreSQL (banco principal) ──────────────────────────────────────────────
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/plantelligence

# ── InfluxDB (telemetria / series temporais) ──────────────────────────────────
INFLUX_URL=https://seu-cluster.azure.influxdata.com
INFLUX_TOKEN=seu-token-influx
INFLUX_ORG=sua-org
INFLUX_BUCKET=plantelligence

# ── SMTP (e-mail de MFA e alertas) ───────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@plantelligence.cloud
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="Plantelligence Security <noreply@plantelligence.cloud>"

# ── MFA / TOTP ────────────────────────────────────────────────────────────────
MFA_DEBUG_MODE=false
MFA_ISSUER=Plantelligence
# MFA_TOTP_SECRET_KEY=   # chave base64 de 32 bytes para criptografar segredos TOTP
