# ── Servidor ────────────────────────────────────────────────────────────────
PORT=4001
FRONTEND_ORIGIN=http://localhost:5173

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-refresh-secret
PASSWORD_RESET_SECRET=change-password-reset-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TTL_SECONDS=900
PASSWORD_EXPIRY_DAYS=90

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5

# ── PostgreSQL (banco principal) ──────────────────────────────────────────────
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/plantelligence

# ── InfluxDB (telemetria / series temporais) ──────────────────────────────────
INFLUX_URL=https://seu-cluster.azure.influxdata.com
INFLUX_TOKEN=seu-token-influx
INFLUX_ORG=sua-org
INFLUX_BUCKET=plantelligence

# ── OpenWeather (clima externo) ─────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=coloque-sua-chave-openweather-aqui

# ── IA (OpenRouter) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-coloque-sua-chave-aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PRIMARY=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL_FALLBACKS=qwen/qwen3-6b-instruct:free,deepseek/deepseek-chat:free

# ── SMTP (e-mail de MFA e alertas) ───────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@plantelligence.cloud
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="Plantelligence <noreply@plantelligence.cloud>"

# URL publica do frontend usada em links de convite/reset
FRONTEND_PUBLIC_URL=http://localhost:5173

# ── MFA / TOTP ────────────────────────────────────────────────────────────────
MFA_DEBUG_MODE=false
MFA_ISSUER=Plantelligence
# MFA_TOTP_SECRET_KEY=   # chave base64 de 32 bytes para criptografar segredos TOTP
